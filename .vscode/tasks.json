{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PIO: Upload then Monitor",
      "type": "shell",
      "command": "pio run --target upload && pio device monitor",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
